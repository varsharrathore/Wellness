# Copy this to .env and fill in your values

NODE_ENV=production

# Port — Railway sets this automatically, leave as is
PORT=5000

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/wellness_store

# Strong random secret for JWT (change this to something long and random!)
JWT_SECRET=change-this-to-a-long-random-secret-string-min-32-chars

# Your deployed frontend URL (only needed if frontend/backend are on different domains)
# Leave empty if deploying together on Railway
FRONTEND_URL=
